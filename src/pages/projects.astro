---
import '../css/global.css'
import NavigationBar from '../components/NavigationBar.astro';
import Footer from '../components/Footer.astro';
import Project from '../components/Project.astro';
---
<head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/Images/VoidWish.png" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>voidcloud04.github.io</title>
</head>
<body>
    <h1><span class="text-gradient-light-purple">Projects</span></h1>
    <hr>
    <NavigationBar />
    <h1>Web Games</h1>
    <Project projectName="Under Pressure" projectDesc="A Game for the NYIGJ 2024" projectLine="https://voidcloud04.github.io/Under-Pressure" color="var(--white)"/>
    <Project projectName="Coop Co" projectDesc="Egg Inc without the MTX", projectLink="https://voidcloud04.github.io/Coop-Co"color="var(--yellow)"/>
    <Project projectName="Chemcremental JS" projectDesc="Remaster of an early project in JS takes inspiration from Synergism", projectLink="https://voidcloud04.github.io/Chemcremental-JS"color="var(--cyan)"/>
    <Project projectName="Pixel Simulation" projectDesc="A prototype particle simulation using HTML Canvases", projectLink="https://voidcloud04.github.io/PixelSimulation"color="var(--blue)"/>
    <h1>Other Programming Projects</h1>
    <Project projectName="Web Accesibility Testing - LLMs" projectDesc="A University Empirical Study on whether or not LLMs can generate accessible webpages" projectLink="https://voidcloud04.github.io/WebAccessibility-LLMs" color="var(--white)"/>
    <Footer />
</body>

<style>
    #projectHolder {
        padding-top:8em;
        margin-left: auto;
        margin-right: auto;
    }
</style>
